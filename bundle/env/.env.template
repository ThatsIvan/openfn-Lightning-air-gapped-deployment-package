

# Pinned Image versions
VERSION=v2.16.7
WS_WORKER_VERSION=v1.26.1
POSTGRES_VERSION=15.12-alpine


# Phoenix session signing key (>=64 chars). Rotating logs everyone out
SECRET_KEY_BASE=

# Credential encryption key (32-byte base64)
PRIMARY_ENCRYPTION_KEY=

# Worker HS256 shared secret (256-bit hex). Set on BOTH web and worker
WORKER_SECRET=

# RSA keypair for per run JWTs (base64 encoded PEM)
WORKER_RUNS_PRIVATE_KEY=
WORKER_LIGHTNING_PUBLIC_KEY=

# Persistance

POSTGRES_USER=lightning
POSTGRES_PASSWORD=
POSTGRES_DB=lightning
# Composed from the above — 02-generate-secrets.sh fills this in.
DATABASE_URL=

# Disable TLS for local Postgres (no certs in scope)
# DISABLE_DB_SSL is set directly in docker-compose.yml

# Network
LISTEN_ADDRESS=0.0.0.0

# External port the host publishes. Clients access http://<URL_HOST>:<LIGHTNING_PORT>
LIGHTNING_PORT=4000

# Set URL_HOST to the server's LAN IP or hostname
URL_HOST=localhost
URL_PORT=4000
URL_SCHEME=http

# Must include the full origin: http://<URL_HOST>:<URL_PORT>
ORIGINS=http://localhost:4000


# Mail
MAIL_PROVIDER=local
EMAIL_ADMIN=admin@localhost


# Worker tuning
# Max concurrent workflow runs. Lower = less memory. 2-4 for 8 GB, 1 for 4 GB
WORKER_CAPACITY=2
# Max memory per single run (MB). 256-500 for 8 GB, 128-256 for 4 GB
WORKER_MAX_RUN_MEMORY_MB=256
# Max wall-clock time per run (seconds).
WORKER_MAX_RUN_DURATION_SECONDS=300


# Logging level (info, debug, warn)
LOG_LEVEL=info


# Adaptors / schemas
# Override only if you mount external files
# ADAPTORS_REGISTRY_JSON_PATH=
# SCHEMAS_PATH=/app/priv/schemas


# Telemetry — OFF (sovereignty)
# Set directly in docker-compose.yml: USAGE_TRACKING_ENABLED=false
# No USAGE_TRACKER_HOST, SENTRY_DSN, PROMEX_ENABLED set
